@{ ViewData["Title"] = "StudyPlanner"; Layout = null; }

<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, minimum-scale=0.5, maximum-scale=5.0, user-scalable=yes" />
    <title>StudyPlanner - Master Your Learning Journey</title>
    <link rel="icon" type="image/png" href="~/logo.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <link href="~/css/site.css" rel="stylesheet" />
    <style>
        /* Landing page specific styles */
        .landing-hero {
            position: relative;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
        }

        .landing-hero-video {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            object-fit: cover;
            z-index: 0;
        }

        .landing-hero-overlay {
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: linear-gradient(
                180deg,
                rgba(15, 15, 35, 0.4) 0%,
                rgba(15, 15, 35, 0.65) 40%,
                rgba(15, 15, 35, 0.9) 75%,
                rgba(15, 15, 35, 1) 100%
            );
            z-index: 1;
        }

        [data-theme="light"] .landing-hero-overlay {
            background: linear-gradient(
                180deg,
                rgba(248, 250, 252, 0.2) 0%,
                rgba(248, 250, 252, 0.5) 40%,
                rgba(248, 250, 252, 0.85) 75%,
                rgba(248, 250, 252, 1) 100%
            );
        }

        .landing-content {
            position: relative;
            z-index: 2;
            text-align: center;
            padding: 2rem 1.5rem;
            max-width: 800px;
        }

        .landing-logo {
            width: 80px;
            height: 80px;
            background: linear-gradient(135deg, var(--primary), var(--accent));
            border-radius: 1.5rem;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 2.25rem;
            color: white;
            margin: 0 auto 2rem;
            animation: fadeInUp 0.6s ease-out;
            box-shadow: 0 12px 40px rgba(99, 102, 241, 0.35);
        }

        .landing-badge {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            background: rgba(99, 102, 241, 0.2);
            border: 1px solid rgba(99, 102, 241, 0.35);
            color: var(--primary-light);
            padding: 0.45rem 1.1rem;
            border-radius: 2rem;
            font-size: 0.8rem;
            font-weight: 600;
            margin-bottom: 1.5rem;
            animation: fadeInUp 0.6s ease-out 0.1s both;
            backdrop-filter: blur(8px);
        }

        .landing-title {
            font-size: clamp(2rem, 5.5vw, 3.8rem);
            font-weight: 800;
            line-height: 1.08;
            margin-bottom: 1.25rem;
            letter-spacing: -0.03em;
            animation: fadeInUp 0.6s ease-out 0.2s both;
        }

        .landing-title .gradient-text {
            background: linear-gradient(135deg, var(--primary-light), var(--accent), #c084fc);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .landing-subtitle {
            font-size: clamp(0.95rem, 2vw, 1.2rem);
            color: var(--text-secondary);
            max-width: 580px;
            margin: 0 auto 2.5rem;
            line-height: 1.6;
            animation: fadeInUp 0.6s ease-out 0.3s both;
        }

        .landing-actions {
            display: flex;
            gap: 1rem;
            justify-content: center;
            flex-wrap: wrap;
            margin-bottom: 4rem;
            animation: fadeInUp 0.6s ease-out 0.4s both;
        }

        .landing-actions .btn {
            padding: 0.75rem 2rem;
            font-size: 1rem;
        }

        /* Features Section */
        .landing-features {
            position: relative;
            z-index: 2;
            padding: 0 1.5rem 4rem;
        }

        .feature-card {
            background: var(--bg-card);
            border: 1px solid var(--border-subtle);
            border-radius: 1rem;
            padding: 2rem 1.5rem;
            text-align: center;
            transition: all 0.3s ease;
            backdrop-filter: blur(10px);
            height: 100%;
        }

        .feature-card:hover {
            transform: translateY(-4px);
            border-color: var(--primary);
            box-shadow: 0 16px 40px rgba(99, 102, 241, 0.12);
        }

        .feature-icon {
            width: 56px;
            height: 56px;
            border-radius: 1rem;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.5rem;
            margin: 0 auto 1.25rem;
        }

        .feature-icon.purple { background: var(--icon-bg-primary); color: var(--primary-light); }
        .feature-icon.green { background: var(--badge-bg-success); color: var(--success); }
        .feature-icon.orange { background: var(--badge-bg-warning); color: var(--warning); }
        .feature-icon.blue { background: var(--badge-bg-info); color: var(--info); }

        .feature-title {
            font-size: 1.05rem;
            font-weight: 700;
            margin-bottom: 0.5rem;
        }

        .feature-desc {
            color: var(--text-muted);
            font-size: 0.9rem;
            line-height: 1.5;
            margin: 0;
        }

        /* Stats bar */
        .landing-stats {
            position: relative;
            z-index: 2;
            display: flex;
            justify-content: center;
            gap: clamp(2rem, 5vw, 4rem);
            flex-wrap: wrap;
            padding: 2.5rem 1.5rem 3rem;
            border-top: 1px solid var(--border-subtle);
            border-bottom: 1px solid var(--border-subtle);
            margin-bottom: 3rem;
        }

        .landing-stat {
            text-align: center;
        }

        .landing-stat-value {
            font-size: clamp(1.5rem, 3vw, 2.2rem);
            font-weight: 800;
            background: linear-gradient(135deg, var(--primary-light), var(--accent));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            line-height: 1.2;
        }

        .landing-stat-label {
            font-size: 0.8rem;
            color: var(--text-muted);
            font-weight: 500;
            margin-top: 0.25rem;
        }

        /* Footer */
        .landing-footer {
            position: relative;
            z-index: 2;
            text-align: center;
            padding: 2rem 1.5rem;
            color: var(--text-muted);
            font-size: 0.85rem;
            border-top: 1px solid var(--border-subtle);
        }

        .landing-footer span {
            color: var(--primary-light);
            font-weight: 600;
        }

        /* Navbar adjustments for landing */
        .landing-nav {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            z-index: 100;
            padding: 1rem 0;
            transition: all 0.3s ease;
        }

        .landing-nav.scrolled {
            background: var(--glass-bg);
            backdrop-filter: blur(20px);
            border-bottom: 1px solid var(--glass-border);
        }

        .landing-nav-inner {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 1.5rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .landing-nav-brand {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            font-size: 1.2rem;
            font-weight: 700;
            background: linear-gradient(135deg, var(--primary-light), var(--accent));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            text-decoration: none;
        }

        .landing-nav-brand img {
            height: 32px;
            width: auto;
        }

        .landing-nav-links {
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .landing-nav-links .btn {
            padding: 0.5rem 1.25rem;
            font-size: 0.875rem;
        }

        /* Theme toggle */
        .landing-theme-toggle {
            display: flex;
            align-items: center;
            justify-content: center;
            width: 40px;
            height: 40px;
            border-radius: 0.75rem;
            border: 1px solid var(--border-subtle);
            background: var(--theme-toggle-bg);
            color: var(--text-secondary);
            cursor: pointer;
            transition: all 0.3s ease;
            font-size: 1.1rem;
            padding: 0;
        }

        .landing-theme-toggle:hover {
            background: var(--theme-toggle-hover);
            color: var(--primary-light);
            border-color: var(--primary);
        }

        @@media (max-width: 767px) {
            .landing-logo {
                width: 64px;
                height: 64px;
                font-size: 1.75rem;
                border-radius: 1.25rem;
            }

            .landing-actions {
                flex-direction: column;
                align-items: center;
            }

            .landing-actions .btn {
                width: 100%;
                max-width: 280px;
            }

            .landing-stats {
                gap: 1.5rem;
            }

            .landing-nav-links .btn span {
                display: none;
            }

            .feature-card {
                padding: 1.5rem 1.25rem;
            }
        }
    </style>
</head>
<body>
    <!-- Landing Navbar -->
    <nav class="landing-nav" id="landingNav">
        <div class="landing-nav-inner">
            <a class="landing-nav-brand" href="/">
                <img src="~/logo.png" alt="StudyPlanner" />
                StudyPlanner
            </a>
            <div class="landing-nav-links">
                <button type="button" class="landing-theme-toggle" id="themeToggle" title="Toggle theme">
                    <i class="bi bi-moon-stars-fill" id="themeIcon"></i>
                </button>
                <a asp-controller="Auth" asp-action="Login" class="btn btn-outline-secondary">
                    <i class="bi bi-box-arrow-in-right me-1"></i><span>Sign In</span>
                </a>
                <a asp-controller="Auth" asp-action="Register" class="btn btn-primary">
                    <i class="bi bi-person-plus me-1"></i><span>Get Started</span>
                </a>
            </div>
        </div>
    </nav>

    <!-- Hero Section -->
    <section class="landing-hero">
        <video class="landing-hero-video" autoplay muted loop playsinline>
            <source src="~/videos/7311107-uhd_2160_4096_25fps.mp4" type="video/mp4" />
        </video>
        <div class="landing-hero-overlay"></div>

        <div class="landing-content">
            <div class="landing-logo">
                <i class="bi bi-book-half"></i>
            </div>
            <div class="landing-badge">
                <i class="bi bi-lightning-charge-fill"></i>
                Smart Study Planning
            </div>
            <h1 class="landing-title">
                Master Your<br /><span class="gradient-text">Learning Journey</span>
            </h1>
            <p class="landing-subtitle">
                Track progress, plan sessions, and optimize your study time with intelligent scheduling. Built for learners who want more from every minute.
            </p>
            <div class="landing-actions">
                <a asp-controller="Auth" asp-action="Register" class="btn btn-primary btn-lg">
                    <i class="bi bi-rocket-takeoff me-2"></i>Start For Free
                </a>
                <a asp-controller="Auth" asp-action="Login" class="btn btn-outline-secondary btn-lg">
                    <i class="bi bi-box-arrow-in-right me-2"></i>Sign In
                </a>
            </div>
        </div>
    </section>

    <!-- Stats -->
    <div class="landing-stats" style="max-width: 900px; margin-left: auto; margin-right: auto;">
        <div class="landing-stat">
            <div class="landing-stat-value">100%</div>
            <div class="landing-stat-label">Free to Use</div>
        </div>
        <div class="landing-stat">
            <div class="landing-stat-value">24/7</div>
            <div class="landing-stat-label">Access Anywhere</div>
        </div>
        <div class="landing-stat">
            <div class="landing-stat-value">3s</div>
            <div class="landing-stat-label">Quick Setup</div>
        </div>
        <div class="landing-stat">
            <div class="landing-stat-value">&infin;</div>
            <div class="landing-stat-label">Unlimited Items</div>
        </div>
    </div>

    <!-- Features -->
    <section class="landing-features" style="max-width: 1000px; margin-left: auto; margin-right: auto;">
        <div class="row g-4">
            <div class="col-md-6 col-lg-3">
                <div class="feature-card">
                    <div class="feature-icon purple">
                        <i class="bi bi-journal-check"></i>
                    </div>
                    <h3 class="feature-title">Track Everything</h3>
                    <p class="feature-desc">Organize study items by category, set priorities, and track your progress over time.</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-3">
                <div class="feature-card">
                    <div class="feature-icon green">
                        <i class="bi bi-calendar-week"></i>
                    </div>
                    <h3 class="feature-title">Plan Sessions</h3>
                    <p class="feature-desc">Auto-schedule study sessions based on available time and review deadlines.</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-3">
                <div class="feature-card">
                    <div class="feature-icon orange">
                        <i class="bi bi-graph-up-arrow"></i>
                    </div>
                    <h3 class="feature-title">See Progress</h3>
                    <p class="feature-desc">Visualize completion rates, study minutes, and identify areas that need attention.</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-3">
                <div class="feature-card">
                    <div class="feature-icon blue">
                        <i class="bi bi-shield-lock"></i>
                    </div>
                    <h3 class="feature-title">Private & Secure</h3>
                    <p class="feature-desc">Your data is personal. Each account is isolated - only you see your study plan.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- CTA -->
    <section style="position: relative; z-index: 2; text-align: center; padding: 3rem 1.5rem 2rem; max-width: 700px; margin: 0 auto;">
        <h2 style="font-size: clamp(1.4rem, 3.5vw, 2rem); font-weight: 800; margin-bottom: 1rem;">
            Ready to Study <span class="gradient-text">Smarter</span>?
        </h2>
        <p style="color: var(--text-muted); margin-bottom: 2rem; font-size: 1rem;">
            Join and start building your personalized study plan in seconds.
        </p>
        <a asp-controller="Auth" asp-action="Register" class="btn btn-primary btn-lg">
            <i class="bi bi-person-plus me-2"></i>Create Free Account
        </a>
    </section>

    <!-- Footer -->
    <footer class="landing-footer">
        <div>
            <span>StudyPlanner</span> &mdash; Built with ASP.NET Core 8 &amp; Onion Architecture
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Theme toggle
        (function() {
            var STORAGE_KEY = 'studyplanner-theme';
            var html = document.documentElement;
            var themeToggle = document.getElementById('themeToggle');
            var themeIcon = document.getElementById('themeIcon');

            var savedTheme = localStorage.getItem(STORAGE_KEY) || 'dark';
            html.setAttribute('data-theme', savedTheme);
            html.setAttribute('data-bs-theme', savedTheme);
            updateIcon(savedTheme);

            themeToggle.addEventListener('click', function() {
                var current = html.getAttribute('data-theme');
                var next = current === 'dark' ? 'light' : 'dark';
                html.setAttribute('data-theme', next);
                html.setAttribute('data-bs-theme', next);
                localStorage.setItem(STORAGE_KEY, next);
                updateIcon(next);
                themeIcon.style.transform = 'rotate(360deg)';
                setTimeout(function() { themeIcon.style.transform = ''; }, 400);
            });

            function updateIcon(theme) {
                themeIcon.className = theme === 'dark' ? 'bi bi-moon-stars-fill' : 'bi bi-sun-fill';
            }
        })();

        // Navbar scroll effect
        (function() {
            var nav = document.getElementById('landingNav');
            if (!nav) return;
            window.addEventListener('scroll', function() {
                nav.classList.toggle('scrolled', window.scrollY > 50);
            }, { passive: true });
        })();

        // Intersection observer for feature cards
        (function() {
            var observer = new IntersectionObserver(function(entries) {
                entries.forEach(function(entry) {
                    if (entry.isIntersecting) {
                        entry.target.classList.add('animate-fade-in-up');
                        observer.unobserve(entry.target);
                    }
                });
            }, { threshold: 0.1, rootMargin: '0px 0px -30px 0px' });

            document.querySelectorAll('.feature-card, .landing-stat').forEach(function(el) {
                el.style.opacity = '0';
                observer.observe(el);
            });
        })();

        // Page load animation
        document.body.style.opacity = '0';
        document.body.style.transition = 'opacity 0.3s ease';
        requestAnimationFrame(function() {
            requestAnimationFrame(function() {
                document.body.style.opacity = '1';
            });
        });
    </script>
</body>
</html>
