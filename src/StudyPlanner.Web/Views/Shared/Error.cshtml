@{ ViewData["Title"] = "Error"; }

<div class="container py-4">
    <div class="empty-state" style="padding: 6rem 2rem;">
        <i class="bi bi-exclamation-triangle d-block" style="font-size: 5rem; color: var(--danger); opacity: 0.7;"></i>
        <h2 class="fw-bold mt-4">Something went wrong</h2>
        <p class="text-muted mb-4">An error occurred while processing your request.</p>
        <a asp-controller="Home" asp-action="Index" class="btn btn-primary">
            <i class="bi bi-house me-1"></i>Go Home
        </a>
    </div>
</div>
