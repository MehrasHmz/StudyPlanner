@model StudyPlanner.Application.DTOs.PaginatedResult<StudyPlanner.Application.DTOs.StudyItemDto>
@{ ViewData["Title"] = "Study Items"; }

<div class="container py-4">
    <div class="section-header">
        <h2><i class="bi bi-journal-text"></i>Study Items</h2>
        <a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-circle me-2"></i>Add New</a>
    </div>

    <div class="card mb-4">
        <div class="card-body">
            <form method="get" class="row g-3 align-items-end">
                <div class="col-md-4">
                    <label class="form-label">Search</label>
                    <input type="text" name="search" value="@Context.Request.Query["search"]" class="form-control" placeholder="Search items..." />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Sort By</label>
                    <select name="sortBy" class="form-select">
                        <option value="created" selected="@(Context.Request.Query["sortBy"]=="created")">Date Created</option>
                        <option value="title" selected="@(Context.Request.Query["sortBy"]=="title")">Title</option>
                        <option value="priority" selected="@(Context.Request.Query["sortBy"]=="priority")">Priority</option>
                        <option value="difficulty" selected="@(Context.Request.Query["sortBy"]=="difficulty")">Difficulty</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label">Order</label>
                    <select name="desc" class="form-select">
                        <option value="true" selected="@(Context.Request.Query["desc"]=="true")">Descending</option>
                        <option value="false" selected="@(Context.Request.Query["desc"]!="true")">Ascending</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-outline-primary w-100"><i class="bi bi-search me-1"></i>Filter</button>
                </div>
            </form>
        </div>
    </div>

    @if (Model.Items.Any())
    {
        <div class="card">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead>
                            <tr>
                                <th>Title</th>
                                <th>Type</th>
                                <th>Difficulty</th>
                                <th>Priority</th>
                                <th>Duration</th>
                                <th>Review</th>
                                <th>Status</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.Items)
                            {
                                <tr>
                                    <td class="fw-semibold">@item.Title</td>
                                    <td><span class="badge bg-secondary">@item.Type</span></td>
                                    <td>
                                        <span class="badge bg-@(item.Difficulty == StudyPlanner.Domain.Enums.DifficultyLevel.Advanced ? "danger" : item.Difficulty == StudyPlanner.Domain.Enums.DifficultyLevel.Intermediate ? "warning" : "success")">
                                            @item.Difficulty
                                        </span>
                                    </td>
                                    <td><span class="badge bg-primary">P@(item.Priority)</span></td>
                                    <td>@item.EstimatedDurationMinutes min</td>
                                    <td>@(item.NextReviewDate?.ToString("MMM dd") ?? "—")</td>
                                    <td>
                                        <form asp-action="ToggleComplete" method="post" class="d-inline">
                                            <input type="hidden" name="id" value="@item.Id" />
                                            <button type="submit" class="btn btn-sm @(item.IsCompleted ? "btn-success" : "btn-outline-success")">
                                                <i class="bi @(item.IsCompleted ? "bi-check-circle-fill" : "bi-circle")"></i>
                                            </button>
                                        </form>
                                    </td>
                                    <td>
                                        <div class="btn-group btn-group-sm">
                                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-primary" title="Edit"><i class="bi bi-pencil"></i></a>
                                            <form asp-action="Delete" method="post" class="d-inline" onsubmit="return confirm('Delete this item?')">
                                                <input type="hidden" name="id" value="@item.Id" />
                                                <button type="submit" class="btn btn-outline-danger" title="Delete"><i class="bi bi-trash"></i></button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        @if (Model.TotalPages > 1)
        {
            <nav class="mt-3">
                <ul class="pagination justify-content-center">
                    @for (int i = 1; i <= Model.TotalPages; i++)
                    {
                        <li class="page-item @(i == Model.Page ? "active" : "")">
                            <a class="page-link" asp-action="Index" asp-route-page="@i" asp-route-search="@Context.Request.Query["search"]" asp-route-sortBy="@Context.Request.Query["sortBy"]" asp-route-desc="@Context.Request.Query["desc"]">@i</a>
                        </li>
                    }
                </ul>
            </nav>
        }
    }
    else
    {
        <div class="empty-state">
            <i class="bi bi-inbox d-block"></i>
            <p>No items found. <a asp-action="Create">Create one!</a></p>
        </div>
    }
</div>
