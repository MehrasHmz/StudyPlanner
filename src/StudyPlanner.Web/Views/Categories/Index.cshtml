@model StudyPlanner.Application.DTOs.PaginatedResult<StudyPlanner.Application.DTOs.CategoryDto>
@{ ViewData["Title"] = "Categories"; }

<div class="container py-4">
    <div class="section-header">
        <h2><i class="bi bi-tags"></i>Categories</h2>
        <a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-circle me-2"></i>Add Category</a>
    </div>

    @if (Model.Items.Any())
    {
        <div class="row g-4">
            @foreach (var cat in Model.Items)
            {
                <div class="col-md-4">
                    <div class="card h-100">
                        <div class="card-body">
                            <h5 class="card-title fw-bold">
                                <i class="bi bi-folder2 me-2 text-primary"></i>@cat.Name
                            </h5>
                            <p class="text-muted mb-3">@cat.Description</p>
                            <div class="d-flex gap-2">
                                <a asp-action="Edit" asp-route-id="@cat.Id" class="btn btn-sm btn-outline-primary">
                                    <i class="bi bi-pencil me-1"></i>Edit
                                </a>
                                <form asp-action="Delete" method="post" onsubmit="return confirm('Delete category?')">
                                    <input type="hidden" name="id" value="@cat.Id" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger">
                                        <i class="bi bi-trash me-1"></i>Delete
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="empty-state">
            <i class="bi bi-folder-x d-block"></i>
            <p>No categories yet. <a asp-action="Create">Create one!</a></p>
        </div>
    }
</div>
